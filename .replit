run = "PYTHONPATH=src streamlit run src/portfolio_analyzer/app.py --server.port 8080 --server.address 0.0.0.0"
entrypoint = "src/portfolio_analyzer/app.py"
modules = ["python-3.12"]

[nix]
channel = "stable-24_05"

[env]
PYTHONPATH = "src"

[deployment]
run = ["sh", "-c", "PYTHONPATH=src streamlit run src/portfolio_analyzer/app.py --server.port 8080 --server.address 0.0.0.0"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 8080
externalPort = 80
